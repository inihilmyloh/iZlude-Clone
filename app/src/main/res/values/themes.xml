<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base Application Theme (Dark) -->
    <style name="Theme.DualSpace" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/on_secondary</item>
        <item name="android:colorBackground">@color/background_dark</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="android:statusBarColor">@color/background_dark</item>
        <item name="android:navigationBarColor">@color/background_dark</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Splash Theme -->
    <style name="Theme.DualSpace.Splash" parent="Theme.DualSpace">
        <item name="android:windowBackground">@color/background_dark</item>
    </style>

    <!-- Card Style -->
    <style name="Widget.DualSpace.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/surface_card</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/divider</item>
    </style>

    <!-- Clone Button Style -->
    <style name="Widget.DualSpace.Button.Clone" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/primary</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">13sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
    </style>

    <!-- Open Button Style -->
    <style name="Widget.DualSpace.Button.Open" parent="Widget.Material3.Button.TonalButton">
        <item name="backgroundTint">@color/secondary</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">13sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Remove Button Style -->
    <style name="Widget.DualSpace.Button.Remove" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/error</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textColor">@color/error</item>
        <item name="android:textSize">13sp</item>
    </style>

    <!-- Search Bar Style -->
    <style name="Widget.DualSpace.SearchBar" parent="">
        <item name="android:background">@drawable/bg_search_bar</item>
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:textColorHint">@color/on_surface_variant</item>
        <item name="android:textSize">15sp</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
    </style>

    <!-- Section Title -->
    <style name="TextAppearance.DualSpace.Title" parent="">
        <item name="android:textSize">22sp</item>
        <item name="android:textColor">@color/on_background</item>
        <item name="android:fontFamily">sans-serif-bold</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <!-- Section Subtitle -->
    <style name="TextAppearance.DualSpace.Subtitle" parent="">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/on_surface_variant</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <!-- App Name in List -->
    <style name="TextAppearance.DualSpace.AppName" parent="">
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/on_background</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:maxLines">1</item>
        <item name="android:ellipsize">end</item>
    </style>

    <!-- App Package Name -->
    <style name="TextAppearance.DualSpace.PackageName" parent="">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/on_surface_variant</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:maxLines">1</item>
        <item name="android:ellipsize">end</item>
    </style>

    <!-- Bottom Nav Label -->
    <style name="TextAppearance.DualSpace.BottomNav" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textSize">12sp</item>
    </style>

    <!-- Dialog Theme -->
    <style name="Theme.DualSpace.Dialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorSurface">@color/surface_elevated</item>
        <item name="materialAlertDialogTitleTextStyle">@style/TextAppearance.DualSpace.Title</item>
    </style>
</resources>
